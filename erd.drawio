          <mxGeometry x="200" y="1240" width="240" height="46" as="geometry" />
        </mxCell>
        <mxCell id="f_adminpanel" value="&lt;b&gt;PANEL ADMIN&lt;/b&gt; (role = admin)&lt;br&gt;&lt;hr&gt;• Dashboard — admin/index.php&lt;br&gt;• Kelola Destinasi — destination_save.php&lt;br&gt;• Kelola Tiket &amp;amp; Fasilitas — tickets.php&lt;br&gt;• Kelola Pesanan &amp;amp; Status&lt;br&gt;• Kelola Pengguna" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="f1">
