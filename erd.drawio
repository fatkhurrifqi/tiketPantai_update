        <mxCell id="f_eticket" value="&lt;b&gt;E-TIKET&lt;/b&gt;&lt;br&gt;Lihat di Pesanan Saya&lt;br&gt;&lt;i&gt;orders.php&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=12;" vertex="1" parent="f1">
