        <mxCell id="f_review" value="&lt;b&gt;BERI ULASAN&lt;/b&gt;&lt;br&gt;Rating &amp;amp; komentar destinasi&lt;br&gt;&lt;i&gt;reviews&lt;/i&gt; (review_save.php)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=12;" vertex="1" parent="f1">
