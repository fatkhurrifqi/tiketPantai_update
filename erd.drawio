        <mxCell id="f_decision" value="Pembayaran diterima?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=12;fontStyle=1;" vertex="1" parent="f1">
          <mxGeometry x="210" y="864" width="220" height="90" as="geometry" />
        </mxCell>
        <mxCell id="f_cancel" value="&lt;b&gt;Dibatalkan&lt;/b&gt;&lt;br&gt;pesanan gagal / dibatalkan" style="ellipse;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=12;" vertex="1" parent="f1">
          <mxGeometry x="560" y="876" width="200" height="66" as="geometry" />
        </mxCell>
        <mxCell id="f_paid" value="&lt;b&gt;STATUS: DIBAYAR → SELESAI&lt;/b&gt;&lt;br&gt;Admin menandai pesanan lunas (paid / completed)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="f1">
