  <diagram id="flow-tiketpantai" name="Alur Sistem">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="1420" math="0" shadow="0">
      <root>
        <mxCell id="f0" />
        <mxCell id="f1" parent="f0" />
        <mxCell id="f_title" value="Alur Sistem TiketPantai — Register → Login → User → Pesanan → Admin" style="text;html=1;align=left;verticalAlign=middle;fontSize=20;fontStyle=1;fontColor=#333333;" vertex="1" parent="f1">
          <mxGeometry x="40" y="10" width="820" height="34" as="geometry" />
        </mxCell>
        <mxCell id="f_legend" value="Legenda:   (hijau) Mulai / Akhir   (biru) Proses User   (ungu) Simpan DB   (kuning) Proses Admin   (jingga) Keputusan" style="text;html=1;align=left;verticalAlign=middle;fontSize=12;fontColor=#555555;" vertex="1" parent="f1">
          <mxGeometry x="40" y="46" width="820" height="20" as="geometry" />
        </mxCell>
        <mxCell id="f_start" value="MULAI — Pengunjung Baru" style="ellipse;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;fontStyle=1;" vertex="1" parent="f1">
          <mxGeometry x="200" y="80" width="240" height="46" as="geometry" />
        </mxCell>
        <mxCell id="f_register" value="&lt;b&gt;REGISTER&lt;/b&gt;&lt;br&gt;Daftar akun baru (name, email, password)&lt;br&gt;&lt;i&gt;auth/register.php&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="f1">
          <mxGeometry x="160" y="150" width="320" height="64" as="geometry" />
        </mxCell>
        <mxCell id="f_login" value="&lt;b&gt;LOGIN&lt;/b&gt;&lt;br&gt;Masuk dengan email &amp;amp; password&lt;br&gt;&lt;i&gt;auth/login.php&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="f1">
          <mxGeometry x="160" y="238" width="320" height="64" as="geometry" />
        </mxCell>
        <mxCell id="f_home" value="&lt;b&gt;BERANDA&lt;/b&gt;&lt;br&gt;Lihat daftar destinasi (hero, cari, populer)&lt;br&gt;&lt;i&gt;index.php / destinations.php&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="f1">
          <mxGeometry x="160" y="326" width="320" height="64" as="geometry" />
        </mxCell>
        <mxCell id="f_dest" value="&lt;b&gt;PILIH DESTINASI&lt;/b&gt;&lt;br&gt;Lihat detail, tiket masuk &amp;amp; fasilitas&lt;br&gt;&lt;i&gt;destination.php&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="f1">
          <mxGeometry x="160" y="414" width="320" height="64" as="geometry" />
        </mxCell>
        <mxCell id="f_checkout" value="&lt;b&gt;CHECKOUT&lt;/b&gt;&lt;br&gt;Pilih tiket/fasilitas + tanggal kunjungan + metode pembayaran&lt;br&gt;&lt;i&gt;checkout.php&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="f1">
          <mxGeometry x="160" y="502" width="320" height="70" as="geometry" />
        </mxCell>
        <mxCell id="f_process" value="&lt;b&gt;PROSES PESANAN&lt;/b&gt;&lt;br&gt;Simpan ke tabel &lt;b&gt;orders&lt;/b&gt; + &lt;b&gt;order_items&lt;/b&gt;&lt;br&gt;(status awal: pending)&lt;br&gt;&lt;i&gt;process_order.php&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=12;" vertex="1" parent="f1">
          <mxGeometry x="160" y="596" width="320" height="74" as="geometry" />
        </mxCell>
        <mxCell id="f_payment" value="&lt;b&gt;PEMBAYARAN&lt;/b&gt;&lt;br&gt;Transfer Bank / E-Wallet / QRIS / Bayar di Lokasi" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="f1">
          <mxGeometry x="160" y="694" width="320" height="60" as="geometry" />
        </mxCell>
        <mxCell id="f_adminver" value="&lt;b&gt;ADMIN VERIFIKASI PEMBAYARAN&lt;/b&gt;&lt;br&gt;Cek bukti &amp;amp; ubah status pesanan&lt;br&gt;&lt;i&gt;admin/index.php&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="f1">
